# Model weights are ignored by default; the smoke release checkpoint is small
# enough for normal GitHub storage and is intentionally included.
checkpoints/
*.ckpt
*.pth
*.pt
*.onnx
!log/deg_scene/smoke_pointnext_bs8_ep2/checkpoints/
